# ==========================================
# 🛡️ github-agent 专家评审系统配置文件 (混合算力版)
# ==========================================

# ===== 1. 系统运行模式 (AUTO, TURBO, SEQUENTIAL,CLOUD) =====
AGENT_MODE=AUTO

# ===== 2. 线上大模型配置 (Cloud/Premium) =====
# 负责主控决策、深度逻辑审计（如 DeepSeek, Gemini）
CLOUD_LLM_API_KEY=sk-your-cloud-key
CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
CLOUD_LLM_MODEL=deepseek-chat

# ===== 3. 本地大模型配置 (Local/Auxiliary) =====
# 负责数据脱水、文档摘要、简单查重（如 Ollama GLM-PureGPU）
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=GLM-PureGPU

# ===== 4. MCP 服务端配置 =====
MCP_COMMAND=npx
MCP_ARGS=-y,@modelcontextprotocol/server-github
# MCP 环境显式配置 (如 GITHUB_TOKEN)
MCP_ENV=GITHUB_TOKEN=ghp_your_token_here

# Firecrawl MCP（用于网页抓取）至少需要其一：
# 1) 使用官方云服务：填写 FIRECRAWL_API_KEY
# 2) 使用自托管网关：填写 FIRECRAWL_API_URL
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=

# ===== 5. 记忆与持久化 =====
MEMORY_FILE=memory.json
